// Prisma Schema - Verity News
// Database: PostgreSQL with pgvector extension

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// USER MANAGEMENT
// ==========================================

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum AccessStatus {
  PUBLIC
  PAYWALLED
  RESTRICTED
  UNKNOWN
}

enum AiRunStatus {
  PENDING
  COMPLETED
  FAILED
  TIMEOUT
  CANCELLED
}

model User {
  id          String   @id // Firebase UID como ID primario
  email       String   @unique
  name        String?
  picture     String?
  subscriptionPlan SubscriptionPlan @default(FREE) @map("subscription_plan")
  location    String? // Sprint 20: GeolocalizaciÃ³n (ej: "Madrid, EspaÃ±a")
  preferences Json? // User preferences (theme, notifications, etc.)
  usageStats  Json? // Usage tracking (queries, chats, analyses)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  favorites     Favorite[]
  searchHistory SearchHistory[]
  chats         Chat[]

  @@map("users")
}

// ==========================================
// NEWS ARTICLES
// ==========================================

model Article {
  id          String   @id @default(uuid())
  title       String
  description String?
  content     String?  @db.Text
  url         String   @unique
  urlToImage  String?
  source      String
  author      String?
  publishedAt DateTime
  category    String? // DEPRECATED: Usar topicId en su lugar (Sprint 23)
  language    String   @default("es")

  // Sprint 23: Topic Relation (replaces category string)
  topicId String? // Foreign key to Topic
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // RAG fields - pgvector (768 dimensions for Gemini text-embedding-004)
  embedding Unsupported("vector(768)")?

  // AI Analysis fields
  summary           String?   @db.Text // AI-generated summary
  biasScore         Float? // Bias score from 0 (neutral) to 1 (highly biased)
  analysis          String?   @db.Text // JSON string with detailed analysis
  analyzedAt        DateTime? // When the article was analyzed
  internalReasoning String?   @db.Text // Chain-of-Thought for XAI auditing (NOT sent to client)
  accessStatus      AccessStatus @default(UNKNOWN) @map("access_status")
  accessReason      String?      @db.VarChar(180) @map("access_reason")
  analysisBlocked   Boolean      @default(false) @map("analysis_blocked")

  // User features
  isFavorite Boolean @default(false) // Quick favorite toggle (no auth for MVP)

  // Metadata
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  favorites Favorite[]

  @@index([publishedAt])
  @@index([source])
  @@index([category])
  @@index([topicId]) // Sprint 23: Index for topic filtering
  @@index([analyzedAt])
  @@index([accessStatus])
  @@index([analysisBlocked])
  @@map("articles")
}

// ==========================================
// USER FAVORITES
// ==========================================

model Favorite {
  userId    String
  articleId String
  createdAt DateTime @default(now())

  // PRIVACY FIX (Sprint 18.2): Distinguish "Like" from "Analysis Unlocked"
  // - false: User only liked (â¤ï¸) the article (no analysis access)
  // - true: User requested analysis (âœ¨) and can see AI data
  unlockedAnalysis Boolean @default(false)

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId]) // Clave primaria compuesta
  @@map("favorites")
}

// ==========================================
// SEARCH HISTORY
// ==========================================

model SearchHistory {
  id           String   @id @default(uuid())
  userId       String
  query        String
  filters      String?  @db.Text // JSON string with filters applied
  resultsCount Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("search_history")
}

// ==========================================
// CHAT CONVERSATIONS
// ==========================================

model Chat {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  role      String // 'user' | 'assistant' | 'system'
  content   String   @db.Text
  sources   String?  @db.Text // JSON array with source articles
  createdAt DateTime @default(now())

  // Relations
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("messages")
}

// ==========================================
// SYSTEM METADATA
// ==========================================

model IngestMetadata {
  id            String   @id @default(uuid())
  source        String // 'newsapi' | 'google-news'
  lastFetch     DateTime
  articlesCount Int      @default(0)
  status        String // 'success' | 'error'
  errorMessage  String?  @db.Text

  @@map("ingest_metadata")
}

// Sprint 24: RSS Source Discovery for Local News
model Source {
  id          String   @id @default(uuid())
  name        String // Name of the news outlet (e.g., "El Diario Vasco")
  url         String   @unique // RSS feed URL
  category    String // 'local' | 'general' | 'deportes' | etc.
  location    String? // City/region for local sources (e.g., "Bilbao")
  reliability String // 'high' | 'medium' | 'low' (AI-assessed reliability)
  isActive    Boolean  @default(true) // Can be disabled if feed fails repeatedly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([location])
  @@index([category])
  @@map("sources")
}

model Topic {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  order       Int?
  createdAt   DateTime @default(now())

  // Relations
  articles Article[] // Sprint 23: Articles belong to topics

  @@map("topics")
}

// ==========================================
// AI OBSERVABILITY
// ==========================================

model AiPromptVersion {
  id           String   @id @default(uuid())
  module       String
  promptKey    String   @map("prompt_key")
  version      String
  templateHash String   @map("template_hash")
  sourceFile   String   @map("source_file")
  isActive     Boolean  @default(true) @map("is_active")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  runs AiOperationRun[]

  @@unique([module, promptKey, version])
  @@unique([templateHash])
  @@index([module, promptKey, isActive], map: "idx_ai_prompt_versions_module_key_active")
  @@map("ai_prompt_versions")
}

model AiModelPricing {
  id                    String   @id @default(uuid())
  provider              String
  model                 String
  currency              String   @default("EUR")
  inputCostMicrosPer1M  BigInt   @map("input_cost_micros_per_1m")
  outputCostMicrosPer1M BigInt   @map("output_cost_micros_per_1m")
  isActive              Boolean  @default(true) @map("is_active")
  validFrom             DateTime @default(now()) @map("valid_from")
  validTo               DateTime? @map("valid_to")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([provider, model, isActive], map: "idx_ai_model_pricing_provider_model_active")
  @@index([validFrom], map: "idx_ai_model_pricing_valid_from")
  @@map("ai_model_pricing")
}

model AiOperationRun {
  id                     String      @id @default(uuid())
  module                 String
  operationKey           String      @map("operation_key")
  provider               String?
  model                  String?
  status                 AiRunStatus @default(PENDING)
  promptVersionId        String?     @map("prompt_version_id")
  requestId              String      @map("request_id")
  correlationId          String      @map("correlation_id")
  endpoint               String?
  userId                 String?     @map("user_id")
  entityType             String?     @map("entity_type")
  entityId               String?     @map("entity_id")
  promptTokens           Int?        @map("prompt_tokens")
  completionTokens       Int?        @map("completion_tokens")
  totalTokens            Int?        @map("total_tokens")
  estimatedCostMicrosEur BigInt?     @map("estimated_cost_micros_eur")
  latencyMs              Int?        @map("latency_ms")
  errorCode              String?     @map("error_code")
  errorMessage           String?     @db.Text @map("error_message")
  metadataJson           Json?       @map("metadata_json")
  debugPayloadJson       Json?       @map("debug_payload_json")
  debugPayloadExpiresAt  DateTime?   @map("debug_payload_expires_at")
  completedAt            DateTime?   @map("completed_at")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  promptVersion AiPromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  @@index([createdAt], map: "idx_ai_operation_runs_created_at")
  @@index([module, operationKey, createdAt], map: "idx_ai_operation_runs_module_operation_created")
  @@index([provider, model, createdAt], map: "idx_ai_operation_runs_provider_model_created")
  @@index([status, createdAt], map: "idx_ai_operation_runs_status_created")
  @@index([requestId], map: "idx_ai_operation_runs_request_id")
  @@index([entityType, entityId, createdAt], map: "idx_ai_operation_runs_entity_created")
  @@index([correlationId], map: "idx_ai_operation_runs_correlation_id")
  @@map("ai_operation_runs")
}
