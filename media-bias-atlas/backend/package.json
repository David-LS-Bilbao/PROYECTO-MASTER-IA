{
  "name": "media-bias-atlas-backend",
  "version": "1.0.0",
  "description": "Media Bias Atlas API - Backend Monolith",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "npx prisma generate && rimraf dist && tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "db:setup": "npx tsx scripts/setup-db.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:seed:manual": "npx tsx scripts/seed-manual-outlets.ts",
    "db:seed:spain": "npx tsx scripts/seed-manual-outlets.ts --country=ES",
    "db:seed:uk": "npx tsx scripts/seed-manual-outlets.ts --country=GB",
    "db:seed:france": "npx tsx scripts/seed-manual-outlets.ts --country=FR",
    "db:seed:germany": "npx tsx scripts/seed-manual-outlets.ts --country=DE",
    "db:seed:usa": "npx tsx scripts/seed-manual-outlets.ts --country=US",
    "maintenance:reclassify-political": "npx tsx scripts/reclassify-political-articles.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "prisma": "^5.10.2",
    "rss-parser": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.0",
    "pg": "^8.11.3",
    "rimraf": "^5.0.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
