# Servidor Base
PORT=3001
NODE_ENV=development

# Base de datos (Media Bias Atlas)
# Apunta al mismo PostgreSQL que Verity News (localhost:5433 por defecto en dev)
DATABASE_URL="postgresql://admin:adminpassword@localhost:5433/media_bias_atlas?schema=public"

# IA para analisis ideologico por articulo
# disabled -> no llama a ningun proveedor externo
BIAS_AI_PROVIDER=disabled
BIAS_AI_API_KEY=
BIAS_AI_MODEL=
BIAS_AI_BASE_URL="https://api.openai.com/v1"
BIAS_AI_TIMEOUT_MS=20000
