# Servidor Base
PORT=3001
NODE_ENV=development

# Base de datos (Media Bias Atlas)
# Apunta al mismo PostgreSQL que Verity News (localhost:5433 por defecto en dev)
DATABASE_URL="postgresql://admin:adminpassword@localhost:5433/media_bias_atlas?schema=public"

# IA para analisis ideologico por articulo
# Opciones soportadas:
# - disabled
# - gemini            -> alineado con Verity News (Google AI Studio)
# - openai-compatible -> OpenAI / OpenRouter / compatibles
BIAS_AI_PROVIDER=disabled
# API key del proveedor elegido.
# En Gemini corresponde a la key de Google AI Studio / Gemini API.
BIAS_AI_API_KEY=
# Modelo:
# - gemini: opcional, por defecto gemini-2.5-flash
# - openai-compatible: obligatorio
BIAS_AI_MODEL=
# Solo aplica a openai-compatible.
BIAS_AI_BASE_URL="https://api.openai.com/v1"
# Timeout global en milisegundos para la llamada IA.
BIAS_AI_TIMEOUT_MS=20000
